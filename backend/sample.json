{
  "questionId": 1,
  "title": "Add Two Numbers",
  "description": "Given two integers a and b, return their sum.",
  "difficulty": "easy",
  "tags": ["math", "addition"],
  "exampleTestCases": [
    {
      "input": "3 7",
      "output": "10",
      "explanation": "3 + 7 = 10"
    },
    {
      "input": "-5 12",
      "output": "7",
      "explanation": "-5 + 12 = 7"
    }
  ],
  "constraints": "-10^9 <= a, b <= 10^9",
  "hints": ["Read two numbers from input", "Return their sum"],
  "hiddenTestCases": [
    {
      "input": "100 200",
      "output": "300"
    },
    {
      "input": "-500 -600",
      "output": "-1100"
    },
    {
      "input": "0 0",
      "output": "0"
    }
  ],
  "starterCode": [
    {
      "language": "javascript",
      "code": "function addTwoNumbers(a, b) {\n  return a + b;\n}"
    },
    {
      "language": "python",
      "code": "def add_two_numbers(a, b):\n    return a + b"
    },
    {
      "language": "java",
      "code": "public static int addTwoNumbers(int a, int b) {\n    return a + b;\n}"
    }
  ],
  "referenceSolutions": [
    {
      "language": "javascript",
      "code": "const fs = require('fs'); const [a,b] = fs.readFileSync(0,'utf8').trim().split(' ').map(Number); console.log(a+b);"
    },
    {
      "language": "python",
      "code": "a,b = map(int,input().split()); print(a+b)"
    },
    {
      "language": "java",
      "code": "Scanner sc = new Scanner(System.in); int a=sc.nextInt(); int b=sc.nextInt(); System.out.println(a+b);"
    }
  ]
}

